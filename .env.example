# Copy to .env.local and fill in real values. Never commit .env.local.

# Postgres connection string
DATABASE_URL=postgres://user:password@localhost:5432/wildcat_copilot

# Google OAuth (teacher authentication)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Session/auth signing secret, 32+ chars
AUTH_SECRET=

# Object storage (uploaded course documents)
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# LLM provider
LLM_PROVIDER_API_KEY=
