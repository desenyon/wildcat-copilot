# Copy to .env.local and fill in real values. Never commit .env.local.

# Postgres connection string. `docker compose up -d` starts a matching local instance.
DATABASE_URL=postgres://wildcat:wildcat_dev_only@localhost:5432/wildcat_copilot

# Google OAuth (teacher authentication)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Session/auth signing secret, 32+ chars. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated list of email addresses allowed to sign in during the pilot.
PILOT_ALLOWLIST=

# Object storage (uploaded course documents). Local dev uses the filesystem
# adapter (lib/documents/storage/local.ts) and only needs OBJECT_STORAGE_BUCKET
# as a local directory name; the other vars are required once a cloud adapter
# is wired up (T4+).
OBJECT_STORAGE_BUCKET=.data/uploads
OBJECT_STORAGE_REGION=local
OBJECT_STORAGE_ACCESS_KEY_ID=local
OBJECT_STORAGE_SECRET_ACCESS_KEY=local

# LLM provider
LLM_PROVIDER_API_KEY=
